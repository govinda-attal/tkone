# Copy to .env and adjust before running docker compose.
# Values here match the docker-compose.yml defaults — change only what you need.

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=tempo
POSTGRES_USER=tempo
POSTGRES_PASSWORD=tempo
POSTGRES_PORT=5432          # host-side port; internal is always 5432

# ── PgBouncer ─────────────────────────────────────────────────────────────────
PGBOUNCER_PORT=5433         # host-side port for direct pgbouncer access

# ── Message Broker (Redpanda / Kafka-compatible) ──────────────────────────────
REDPANDA_KAFKA_PORT=9092
REDPANDA_ADMIN_PORT=9644
REDPANDA_CONSOLE_PORT=8080  # browser UI

# ── Tempo workers ─────────────────────────────────────────────────────────────
TEMPO_DB_URL=postgres://tempo:tempo@pgbouncer:5432/tempo
TEMPO_BROKER_BOOTSTRAP=redpanda:9092

# Topics (must exist on the broker before workers start — see init-topics below)
TEMPO_OUTBOX_TOPIC=tempo.schedule.fired
TEMPO_INBOX_TOPIC=tempo.schedule.completed

RUST_LOG=info
